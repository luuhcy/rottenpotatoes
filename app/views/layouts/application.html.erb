<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "RottenPotatoes" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Inclui CSS -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <!-- Importmap para Turbo e suporte a link_to method: :delete -->
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
      <h1>RottenPotatoes</h1>
      <hr>
    </header>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
