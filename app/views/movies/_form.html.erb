<%= form_with(model: @movie) do |form| %>
    <% if @movie.errors.any? %>
      <div id="error_explanation">
        <h2><%= pluralize(@movie.errors.count, "error") %> proibiu este filme de ser salvo:</h2>
        <ul>
          <% @movie.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  
    <p>
      <%= form.label :title %><br>
      <%= form.text_field :title %>
    </p>
  
    <p>
      <%= form.label :rating %><br>
      <%= form.text_field :rating %>
    </p>
  
    <p>
      <%= form.label :release_date %><br>
      <%= form.date_select :release_date %>
    </p>
  
    <p>
      <%= form.submit %>
    </p>
  <% end %>
  